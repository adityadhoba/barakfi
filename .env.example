# ============================================================================
# BARAKFI — BACKEND ENVIRONMENT VARIABLES
# ============================================================================
#
# Copy this file to .env and fill in the values for your environment.
# Required variables are marked [REQUIRED]. Optional ones are marked [OPTIONAL].
# See ARCHITECTURE.md for detailed setup instructions.

# ============================================================================
# APPLICATION SETUP
# ============================================================================

# [REQUIRED] Database connection string
# SQLite (development): sqlite:///./test.db
# PostgreSQL (production): postgresql://user:password@localhost/barakfi_db
DATABASE_URL=sqlite:///./test.db

# Application metadata
APP_NAME=Barakfi API
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=false

# API server settings
API_HOST=127.0.0.1
API_PORT=8001

# [REQUIRED] CORS allowed origins (comma-separated)
# Include the frontend URL(s) that will call this backend
# Example: http://localhost:3000,https://barakfi.in
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================================
# AUTHENTICATION (Clerk.com)
# ============================================================================

# [REQUIRED] Clerk authentication provider
AUTH_PROVIDER=clerk

# [REQUIRED] Clerk keys from https://dashboard.clerk.com
# pk_test_xxx for development, pk_live_xxx for production
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# [REQUIRED] Clerk secret key (keep secure!)
CLERK_SECRET_KEY=sk_test_your_key_here

# [REQUIRED] Clerk JWKS endpoint URL (auto-validated, rarely changes)
CLERK_JWKS_URL=https://api.clerk.com/v1/jwks

# [OPTIONAL] Clerk JS URL (snippet URL if using Clerk UI components)
CLERK_JS_URL=

# [REQUIRED] Admin access control — comma-separated Clerk user IDs
# Get these from Clerk dashboard: https://dashboard.clerk.com/users
# Example: user_abc123xyz,user_def456uvw
ADMIN_AUTH_SUBJECTS=your-clerk-user-id

# [REQUIRED] Admin access control — comma-separated email addresses
# Any user with these emails will have admin access
ADMIN_EMAILS=adityadhoba@gmail.com

# Screening quota — daily limits per IST day (resets at midnight IST)
ANON_SCREENS_PER_DAY=2
AUTH_SCREENS_PER_DAY=5
COMPARE_PER_DAY=1
PEER_COMPARISON_PER_DAY=1

# [REQUIRED] Authorized parties for JWT validation (usually same as CORS_ORIGINS)
# List of frontend URLs that are allowed to send auth tokens
AUTHORIZED_PARTIES=http://localhost:3000

# [REQUIRED] Internal service-to-service token (for background jobs)
# Keep this secret! Change from default on production.
# Must match BACKEND_SERVICE_TOKEN in frontend .env.local
INTERNAL_SERVICE_TOKEN=dev-internal-token-change-me-in-production
OPS_SLACK_WEBHOOK_URL=
OPS_ALERT_FAILURES_ENABLED=true
OPS_ALERT_SUCCESSES_ENABLED=true
OPS_ALERT_JOB_A_SUCCESSES_ENABLED=false
OPS_ALERT_QUIET_WINDOW_ENABLED=false
OPS_ALERT_QUIET_WINDOW_SECONDS=1800
# Job A (yfinance) throttling safety for shared/cloud egress IPs
YF_RATE_LIMIT_SECONDS=1.5
YF_MAX_RETRIES=5
YF_RETRY_BASE_SECONDS=15
YF_RETRY_MAX_SECONDS=180
YF_COOLDOWN_TRIGGER_CONSECUTIVE=5
YF_COOLDOWN_SECONDS=180

# ============================================================================
# MARKET DATA & FUNDAMENTALS PROVIDERS
# ============================================================================

# [REQUIRED] Choose market data provider for stock prices
# Options:
#   seed — demo dataset (10-20 hardcoded stocks, no live data)
#   auto_india — tries NSE first, falls back to Yahoo (public APIs)
#   nse_public — official NSE India API only
#   yahoo_india — Yahoo Finance only
#   groww, kite, upstox — broker APIs (needs API keys, not fully implemented)
MARKET_DATA_PROVIDER=auto_india

# [REQUIRED] Choose fundamentals provider (balance sheet, income statement)
# Options:
#   seed — demo dataset (limited fields)
#   nse — NSE India fundamentals (partial implementation)
#   groww, kite, upstox — broker APIs (needs API keys, not fully implemented)
FUNDAMENTALS_PROVIDER=seed

# [OPTIONAL] Financial Modeling Prep — fundamentals probe / future ingestion (free tier ~250 calls/day)
# https://site.financialmodelingprep.com/developer/docs/pricing
FMP_API_KEY=

# [OPTIONAL] Broker API credentials (fill when using broker-based providers)
# Only needed if MARKET_DATA_PROVIDER or FUNDAMENTALS_PROVIDER is set to groww/kite/upstox

# Groww API (https://groww.in/developer)
GROWW_API_KEY=
GROWW_ACCESS_TOKEN=

# Zerodha Kite API (https://kite.trade/)
KITE_API_KEY=
KITE_ACCESS_TOKEN=

# Upstox API (https://upstox.com/developer)
UPSTOX_ACCESS_TOKEN=

# Other market data providers (research only)
SIGNALX_API_KEY=
XARO_API_KEY=

# ============================================================================
# DEVELOPMENT & DEBUGGING
# ============================================================================

# Enable detailed API logging (verbose, not recommended for production)
# Options: true, false
DETAILED_LOGGING=false

# Maximum stocks to process in bulk operations (prevents memory spikes)
# Example: 1000
MAX_BULK_PROCESS_SIZE=1000

# Cache expiration time for fundamentals (seconds)
# Example: 86400 = 24 hours
FUNDAMENTALS_CACHE_TTL=86400

# ============================================================================
# OPTIONAL: Google OAuth Configuration
# ============================================================================

# [OPTIONAL] Enable Google OAuth as social connection to Clerk
# Clerk handles the OAuth setup internally; these are informational
AUTH_GOOGLE_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# On-demand ISR revalidation (screener cache purge after pipeline runs)
# FRONTEND_URL is the public URL of the Next.js app (no trailing slash)
FRONTEND_URL=https://barakfi.in
# REVALIDATE_SECRET must match the value set in the Vercel environment variables
REVALIDATE_SECRET=
