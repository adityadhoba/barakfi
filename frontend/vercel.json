{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["bom1"],
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "barakfi.com" }],
      "destination": "https://barakfi.in/:path",
      "permanent": true
    },
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.barakfi.com" }],
      "destination": "https://barakfi.in/:path",
      "permanent": true
    },
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.barakfi.in" }],
      "destination": "https://barakfi.in/:path",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-pipeline",
      "schedule": "15 12 * * 1-5"
    }
  ],
  "headers": [
    {
      "source": "/icons/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
