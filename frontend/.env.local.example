# ═══════════════════════════════════════════════════════════════
# Barakfi Frontend — Environment Variables
# Copy to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Clerk Authentication ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx
# Optional: force Clerk JS/UI bundles to the official CDN to avoid custom-domain redirect issues
NEXT_PUBLIC_CLERK_JS_URL=https://cdn.jsdelivr.net/npm/@clerk/clerk-js@6/dist/clerk.browser.js
NEXT_PUBLIC_CLERK_UI_URL=https://cdn.jsdelivr.net/npm/@clerk/ui@1/dist/ui.browser.js

# ── Backend API (FastAPI — must NOT be the Vercel site URL) ──
# Use your API host + /api, e.g. https://api.barakfi.in/api
# Wrong: https://barakfi.in (that is the Next.js frontend; proxies will 404/500)
NEXT_PUBLIC_API_BASE_URL=https://api.barakfi.in/api

# ── Site URL ──
NEXT_PUBLIC_SITE_URL=https://barakfi.in

# ── Google Search Console Verification (for SEO) ──
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Internal Service Token (must match backend) ──
BACKEND_SERVICE_TOKEN=generate-a-random-token-here

# ── PostHog Analytics (optional) ──
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Logo.dev (stock logos via ticker API) ──
NEXT_PUBLIC_LOGO_DEV_TOKEN=
