# ═══════════════════════════════════════════════════════════
# Barakfi — Production Environment
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Application ──
APP_ENV=production
DEBUG=false

# ── Database ──
# SQLite (development): sqlite:///./data/barakfi.db
# PostgreSQL (production): postgresql://user:pass@host:5432/barakfi
DATABASE_URL=sqlite:///./data/barakfi.db

# ── CORS ──
CORS_ORIGINS=https://barakfi.in,https://barakfi.com,https://www.barakfi.in,https://www.barakfi.com,http://localhost:3000

# ── Authentication (Clerk) ──
AUTH_PROVIDER=clerk
CLERK_SECRET_KEY=sk_live_xxxx
CLERK_JWKS_URL=https://pretty-arachnid-85.clerk.accounts.dev/.well-known/jwks.json
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxx

# ── Frontend ──
NEXT_PUBLIC_API_BASE_URL=https://api.barakfi.in/api
NEXT_PUBLIC_SITE_URL=https://barakfi.in

# ── Google Search Console (for SEO verification) ──
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Market Data ──
# Options: seed, auto_india, nse_public, yahoo_india, groww, kite, upstox
MARKET_DATA_PROVIDER=auto_india

# Broker APIs (optional - for real-time data)
# GROWW_API_KEY=
# GROWW_ACCESS_TOKEN=
# KITE_API_KEY=
# KITE_ACCESS_TOKEN=
# UPSTOX_ACCESS_TOKEN=

# ── Fundamentals Provider ──
# Options: seed, signalx, xaro
FUNDAMENTALS_PROVIDER=seed
# SIGNALX_API_KEY=
# XARO_API_KEY=

# ── Admin ──
ADMIN_AUTH_SUBJECTS=
ADMIN_EMAILS=aditya.dhoba@merqube.com

# ── Internal Service Token ──
# Used for service-to-service calls (price sync, user provisioning)
INTERNAL_SERVICE_TOKEN=generate-a-random-token-here
OPS_SLACK_WEBHOOK_URL=
OPS_ALERT_FAILURES_ENABLED=true
OPS_ALERT_SUCCESSES_ENABLED=true
OPS_ALERT_JOB_A_SUCCESSES_ENABLED=false
OPS_ALERT_QUIET_WINDOW_ENABLED=false
OPS_ALERT_QUIET_WINDOW_SECONDS=1800
# Job A (yfinance) throttling safety for shared/cloud egress IPs
YF_RATE_LIMIT_SECONDS=1.5
YF_MAX_RETRIES=5
YF_RETRY_BASE_SECONDS=15
YF_RETRY_MAX_SECONDS=180
YF_COOLDOWN_TRIGGER_CONSECUTIVE=5
YF_COOLDOWN_SECONDS=180
JOB_A_MAX_FAILED_SYMBOLS=3
